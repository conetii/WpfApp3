<Page x:Class="WpfApp3.Pages.HelpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="HelpPage"
      Background="{DynamicResource WindowBackgroundBrush}">
    <Page.Resources>
        <Style x:Key="StepIndicatorBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
        </Style>

        <Style x:Key="CardRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder"
                                Width="280"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Ellipse x:Name="SelectionDot"
                                         Width="10"
                                         Height="10"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Fill="{DynamicResource AccentBrush}"
                                         Visibility="Collapsed"/>
                                <ContentPresenter Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="SelectionDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="24" Background="{DynamicResource WindowBackgroundBrush}">
            <StackPanel MaxWidth="980">
                <Border Padding="24"
                        Background="{DynamicResource SurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource PopupBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel>
                        <TextBlock x:Name="TitleTextBlock"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="DescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,22,0,0">
                            <Border x:Name="Step1IndicatorBorder" Style="{StaticResource StepIndicatorBorderStyle}">
                                <TextBlock x:Name="Step1IndicatorTextBlock" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="Step2IndicatorBorder" Style="{StaticResource StepIndicatorBorderStyle}">
                                <TextBlock x:Name="Step2IndicatorTextBlock" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="Step3IndicatorBorder" Style="{StaticResource StepIndicatorBorderStyle}">
                                <TextBlock x:Name="Step3IndicatorTextBlock" FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,0"
                        Padding="24"
                        Background="{DynamicResource SurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource PopupBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <StackPanel x:Name="Step1Panel">
                            <TextBlock x:Name="Step1TitleTextBlock"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="Step1DescriptionTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <WrapPanel Margin="0,20,0,0">
                                <RadioButton x:Name="FolderScenarioRadioButton"
                                             GroupName="QuickStartScenario"
                                             Style="{StaticResource CardRadioButtonStyle}"
                                             Checked="ScenarioSelectionChanged">
                                    <StackPanel>
                                        <TextBlock x:Name="FolderScenarioTitleTextBlock" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="FolderScenarioBodyTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="EncryptedScenarioRadioButton"
                                             GroupName="QuickStartScenario"
                                             Style="{StaticResource CardRadioButtonStyle}"
                                             Checked="ScenarioSelectionChanged">
                                    <StackPanel>
                                        <TextBlock x:Name="EncryptedScenarioTitleTextBlock" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="EncryptedScenarioBodyTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="SingleFileScenarioRadioButton"
                                             GroupName="QuickStartScenario"
                                             Style="{StaticResource CardRadioButtonStyle}"
                                             Checked="ScenarioSelectionChanged">
                                    <StackPanel>
                                        <TextBlock x:Name="SingleFileScenarioTitleTextBlock" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="SingleFileScenarioBodyTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                            <TextBlock x:Name="Step2TitleTextBlock"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="Step2DescriptionTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>

                            <StackPanel x:Name="FolderDetailsPanel" Margin="0,22,0,0">
                                <TextBlock x:Name="FolderDetailsTitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="FolderDetailsHintTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="FolderPathLabelTextBlock" Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FolderPathTextBox"
                                             Padding="12,9"
                                             FontSize="14"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource SurfaceBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             TextChanged="InputTextChanged"/>
                                    <Button x:Name="FolderBrowseButton"
                                            Grid.Column="1"
                                            MinWidth="120"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="FolderBrowseButton_Click"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="EncryptedDetailsPanel" Margin="0,22,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="EncryptedDetailsTitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentAltBrush}"/>
                                <TextBlock x:Name="EncryptedDetailsHintTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="EncryptedModeLabelTextBlock" Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <RadioButton x:Name="OpenEncryptedModeRadioButton"
                                             GroupName="EncryptedMode"
                                             Style="{StaticResource CardRadioButtonStyle}"
                                             Checked="ModeSelectionChanged">
                                        <TextBlock x:Name="OpenEncryptedModeTextBlock" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </RadioButton>
                                    <RadioButton x:Name="CreateEncryptedModeRadioButton"
                                             GroupName="EncryptedMode"
                                             Style="{StaticResource CardRadioButtonStyle}"
                                             Checked="ModeSelectionChanged">
                                        <TextBlock x:Name="CreateEncryptedModeTextBlock" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </RadioButton>
                                </WrapPanel>
                                <TextBlock x:Name="EncryptedPathLabelTextBlock" Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="EncryptedPathTextBox"
                                             Padding="12,9"
                                             FontSize="14"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource SurfaceBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             TextChanged="InputTextChanged"/>
                                    <Button x:Name="EncryptedBrowseButton"
                                            Grid.Column="1"
                                            MinWidth="120"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="EncryptedBrowseButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="PasswordLabelTextBlock" Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <PasswordBox x:Name="EncryptedPasswordBox"
                                             Margin="0,8,0,0"
                                             Padding="12,9"
                                             FontSize="14"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource SurfaceBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             PasswordChanged="InputPasswordChanged"/>
                                <StackPanel x:Name="ConfirmPasswordPanel" Margin="0,18,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="ConfirmPasswordLabelTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <PasswordBox x:Name="EncryptedConfirmPasswordBox"
                                                 Margin="0,8,0,0"
                                                 Padding="12,9"
                                                 FontSize="14"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource SurfaceBackgroundBrush}"
                                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                                 PasswordChanged="InputPasswordChanged"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="SingleFileDetailsPanel" Margin="0,22,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="SingleFileDetailsTitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentAlt2Brush}"/>
                                <TextBlock x:Name="SingleFileDetailsHintTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="SingleFileModeLabelTextBlock" Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <RadioButton x:Name="OpenSingleFileModeRadioButton"
                                                 GroupName="SingleFileMode"
                                                 Style="{StaticResource CardRadioButtonStyle}"
                                                 Checked="ModeSelectionChanged">
                                        <TextBlock x:Name="OpenSingleFileModeTextBlock" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </RadioButton>
                                    <RadioButton x:Name="CreateSingleFileModeRadioButton"
                                                 GroupName="SingleFileMode"
                                                 Style="{StaticResource CardRadioButtonStyle}"
                                                 Checked="ModeSelectionChanged">
                                        <TextBlock x:Name="CreateSingleFileModeTextBlock" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </RadioButton>
                                </WrapPanel>
                                <TextBlock x:Name="SingleFilePathLabelTextBlock" Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SingleFilePathTextBox"
                                             Padding="12,9"
                                             FontSize="14"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource SurfaceBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             TextChanged="InputTextChanged"/>
                                    <Button x:Name="SingleFileBrowseButton"
                                            Grid.Column="1"
                                            MinWidth="120"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SingleFileBrowseButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="SingleFileOutsideStorageHintTextBlock" Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                            <TextBlock x:Name="Step3TitleTextBlock"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="Step3DescriptionTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <Border Margin="0,22,0,0"
                                    Padding="20"
                                    Background="{DynamicResource PanelAltBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock x:Name="SummaryTitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="SummaryActionTextBlock" Margin="0,10,0,0" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SummaryPathTextBlock" Margin="0,10,0,0" FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource TreeFileBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SummaryNoteTextBlock" Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="LaunchHintTextBlock" Margin="0,14,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="ValidationTextBlock"
                           Margin="4,14,0,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource StatusWarningBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <DockPanel Margin="0,18,0,12" LastChildFill="False">
                    <Button x:Name="ResetButton"
                            DockPanel.Dock="Left"
                            MinWidth="120"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ResetButton_Click"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="BackButton"
                                MinWidth="120"
                                Margin="0,0,12,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BackButton_Click"/>
                        <Button x:Name="NextButton"
                                MinWidth="140"
                                Margin="0,0,12,0"
                                Click="NextButton_Click"/>
                        <Button x:Name="LaunchButton"
                                MinWidth="160"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="LaunchButton_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
